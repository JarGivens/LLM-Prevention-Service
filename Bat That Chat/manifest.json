{
  "manifest_version": 3,
  "name": "Bat That Chat",
  "version": "1.0",
  "description": "Redirects major LLM websites to Google",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://huggingface.co/*",
        "https://you.com/*",
        "https://character.ai/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}