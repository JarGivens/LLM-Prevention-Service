{
  "manifest_version": 3,
  "name": "You're Scaring The LLMs",
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "version": "1.0",
  "description": "The LLMs can't stop shaking when they see you! Please stop using them!",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://bard.google.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://huggingface.co/*",
        "https://you.com/*",
        "https://character.ai/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}